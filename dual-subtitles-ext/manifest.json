{
  "manifest_version": 3,
  "name": "DualSub — Dual Subtitle Translator",
  "short_name": "DualSub",
  "version": "2.2.0",
  "description": "Real-time dual subtitles on Netflix, Prime Video, and YouTube. Translate any language pair instantly.",
  "permissions": [
    "activeTab",
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "DualSub — Dual Subtitle Translator"
  },
  "icons": {
    "16":  "icon16.png",
    "48":  "icon48.png",
    "128": "icon128.png"
  }
}
